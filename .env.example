APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# LOG_CHANNEL=daily — один файл на день, старые автоматически удаляются после
# LOG_DAILY_DAYS дней (см. config/logging.php). На проде использовать 'daily'
# чтобы laravel.log не разрастался до десятков ГБ. Локально можно 'stack'.
LOG_CHANNEL=daily
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Сколько дней хранить записи журнала аудита (sheet_audit_logs).
# Команда audit-log:cleanup чистит старше этого значения раз в сутки.
AUDIT_LOG_RETENTION_DAYS=90

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# Google OAuth — для подключения юзеров их Gmail-аккаунтов и отправки писем
# от их имени через Gmail API. Получить:
#   1) Google Cloud Console → APIs & Services → Credentials → Create OAuth Client (Web)
#   2) Authorized redirect URIs: http://127.0.0.1:8000/auth/google/callback (локально)
#                                https://your-domain/auth/google/callback (prod)
#   3) Включить Gmail API в APIs & Services → Library
#   4) В OAuth consent screen добавить scope https://www.googleapis.com/auth/gmail.send
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
