# ============================================================
# Excel Tojiktelecom — Docker .env
# Скопируй в .env и заполни поля помеченные ⚠.
# ============================================================

APP_NAME="Excel Tojiktelecom"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com                          # ⚠ свой домен (или http://server-ip)

# ⚠ ОБЯЗАТЕЛЬНО: сгенерируй командой
#   docker compose run --rm app php artisan key:generate --show
APP_KEY=

LOG_CHANNEL=daily
LOG_DAILY_DAYS=14
LOG_LEVEL=warning
AUDIT_LOG_RETENTION_DAYS=90

# ============================================================
# База данных (postgres-сервис из docker-compose)
# ============================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=excel_db
DB_USERNAME=excel_user
DB_PASSWORD=                                          # ⚠ длинный случайный пароль

# ============================================================
# Redis (redis-сервис из docker-compose)
# ============================================================
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# ============================================================
# Дефолтный админ — создаётся автоматически миграцией
# 2026_05_05_140000_create_default_admin_user при первом запуске.
# После первого входа можно/нужно сменить через /profile.
# ============================================================
ADMIN_EMAIL=admin@example.com                         # ⚠
ADMIN_PASSWORD=                                       # ⚠ длинный случайный пароль
ADMIN_NAME="Главный админ"

# ============================================================
# Mail (отправка писем). Пока в логи; для Gmail OAuth см. /profile.
# ============================================================
MAIL_MAILER=log

# ============================================================
# Google OAuth — нужен только для функции «Отправить таблицу по email».
# Получить тут: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://твой-домен.com/auth/google/callback
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://example.com/auth/google/callback

# ============================================================
# Опционально: на каком порту nginx-контейнер выйдет наружу.
# По умолчанию 80. Поставь 8080 если уже что-то висит на 80.
# ============================================================
NGINX_PORT=80
